# =====================================================
# 1. 实验设计 Design Matrix (UPDATED)
# =====================================================
size_limits_df <- tribble(
~scenario_name, ~min_len_mm, ~max_len_mm,
"Min_9inch",     228.6,      1000,        # 最小9英寸
"Min_10inch",    254,        1000,        # 最小10英寸
"Slot_8_12",     203.2,      304.8,       # 8-12英寸slot limit
"Slot_6_10",     152.4,      254          # 6-10英寸slot limit
)
scenarios_df <- expand_grid(
scenario_name          = size_limits_df$scenario_name,
prop_annual_encounters = c(0.75),          # 固定为0.75
ESD                    = c(0.3, 0.6)       # 环境随机性
) %>%
left_join(size_limits_df, by = "scenario_name") %>%
mutate(
scenario_id = row_number(),
run_label   = paste0("Scenario_", scenario_id),
# Burn-in 阶段使用的参数
comp_mode = 0,
release_mortality = 0.6
)
