# --- 0) 清洗参数库：去掉NA与明显边界解（如 K==5） ---
Theta_clean <- Theta_star %>%
filter(is.finite(Linf), is.finite(K), is.finite(t0),
K > 0, K < 5)          # 去掉K触上界=5的解
# --- 1) 为 N 条新鱼抽样参数（经验重采样：整行抽，保 L∞-K-t0 的相关性） ---
draw_params_empirical <- function(n, Theta_matrix) {
idx <- sample.int(nrow(Theta_matrix), size = n, replace = TRUE)
out <- Theta_matrix[idx, , drop = FALSE]
rownames(out) <- NULL
as.data.frame(out)
}
N_new <- 10000
param_new <- draw_params_empirical(N_new, Theta_trim)
save(Theta_clean, file = "VBGF.RData")
saveRDS(Theta_clean, file = "VBGF.RData")
saveRDS(Theta_clean, file = "VBGF.rds")
# 可选：用分位数轻微修剪极端值（防炸尾；不想修剪就注释掉）
trim_q <- as.data.frame(t(apply(Theta_clean, 2, quantile, c(0.005, 0.995), na.rm = TRUE)))
Theta_trim <- Theta_clean %>%
filter(Linf >= trim_q["0.5%", "Linf"], Linf <= trim_q["99.5%", "Linf"],
K    >= trim_q["0.5%", "K"],    K    <= trim_q["99.5%", "K"],
t0   >= trim_q["0.5%", "t0"],   t0   <= trim_q["99.5%", "t0"])
qs <- apply(Theta_clean, 2, quantile, probs = c(0.005, 0.995), na.rm = TRUE)
# 行1是下界，行2是上界
lo <- qs[1, ]  # 命名向量：Linf/K/t0
hi <- qs[2, ]
# 用 between 过滤（保相关的是“整行抽样”，分位修剪只是去极端）
Theta_trim <- Theta_clean %>%
dplyr::filter(
dplyr::between(Linf, lo["Linf"], hi["Linf"]),
dplyr::between(K,    lo["K"],    hi["K"]),
dplyr::between(t0,   lo["t0"],   hi["t0"])
)
hist(Theta_trim$K)
hist(Theta_trim$t0)
hist(Theta_trim$K)
cor(Theta_trim$Linf, Theta_trim$K)
