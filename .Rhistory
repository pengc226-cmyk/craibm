# -------------------- 跑 1000 次自助，得到“个体参数库” --------------------
Theta_star <- bootstrap_vbgf_po(
wd,
B            = 10000,
phi_obs      = 0.10,        # 观测占比，小=更“松”，sd_sim更大；可试 0.05
proc_mode    = "age",       # "age" 更能放宽参数；"global" 更稳
use_empirical= TRUE,        # 经验残差抽样（厚尾）
max_tries    = 15000L,
max_retries  = 3L,
jitter_sd    = 0.05
)
