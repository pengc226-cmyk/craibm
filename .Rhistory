scale_color_manual(values=c(Observed="#D55E00", Simulated="#1F78B4"),
guide=guide_legend(title=NULL)) +
scale_y_continuous(
name = "Density",
sec.axis = sec_axis(~ . * max_n * bin_w,
name = "Count", labels = comma)
) +
labs(x="Length (mm)",
title="Observed vs Simulated Length Distributions (Ages 0–5)",
subtitle="Semi-transparent histograms overlaid; left axis: density, right axis: counts") +
theme_bw(base_size=12) +
theme(
legend.position = "top",
legend.box = "vertical",
panel.grid = element_blank(),
strip.background = element_rect(fill="#F3F3F3", color=NA),
strip.text = element_text(face="bold"),
plot.title = element_text(face="bold")
)
# 计算一年步长的增量
deltaL <- function(age, Linf, K, t0)
Linf * exp(-K * (age - t0)) * (1 - exp(-K))
ages <- 0:10
nfish <- nrow(Theta_star)
# 初始化矩阵：每行一条鱼、每列一个年龄
Lmat <- matrix(NA_real_, nrow = nfish, ncol = length(ages))
colnames(Lmat) <- paste0("age", ages)
# 0龄长度按VBGF算起点
Lmat[,1] <- with(Theta_star, L_vbgf(0, Linf, K, t0))
# 递推更新
for (a in 1:10) {
mu <- with(Theta_star, deltaL(a-1, Linf, K, t0))
Lmat[,a+1] <- Lmat[,a] + mu
}
# 汇总对比
sim_long <- as.data.frame(Lmat) %>%
pivot_longer(everything(), names_to = "AgeLab", values_to = "Length") %>%
mutate(Age = as.integer(sub("age","", AgeLab)))
sim_sum <- sim_long %>%
group_by(Age) %>%
summarise(mn_sim = mean(Length),
sd_sim = sd(Length),
q95_sim = quantile(Length, 0.95),
.groups = "drop")
obs_sum <- wd %>%
filter(Age %in% 0:5) %>%
group_by(Age) %>%
summarise(n = n(),
mn_obs = mean(Length),
sd_obs = sd(Length),
q95_obs = quantile(Length, 0.95),
.groups = "drop")
out_tbl <- left_join(obs_sum, sim_sum, by = "Age")
print(out_tbl, n = Inf)
library(ggplot2)
library(dplyr)
library(tidyr)
# 需要：
# - sim_long: 模拟长表（Age, Length）
# - obs_sum : 观测每龄统计（Age, n, mn_obs, sd_obs）
# - out_tbl : 对比表（含 mn_sim, sd_sim），或你也可从 sim_long再算
ages_plot <- 0:5
xlim_fix  <- c(0, 400)
nbins     <- 30
# 观测原始长度（直方图用它，不是均值±sd）
obs_raw <- wd %>%
filter(Age %in% ages_plot) %>%
select(Age, Length) %>%
mutate(Source = "Observed")
# 模拟长度
sim_raw <- sim_long %>%
filter(Age %in% ages_plot) %>%
mutate(Source = "Simulated")
# 两层直方图的数据合并
hdat <- bind_rows(obs_raw, sim_raw)
# 模拟的核密度（每龄单独算，y 用 density 便于与直方图对齐）
sim_curve <- sim_raw %>%
group_by(Age) %>%
summarise(dens = list(density(Length, from = xlim_fix[1], to = xlim_fix[2], na.rm = TRUE)),
.groups = "drop") %>%
mutate(df = lapply(dens, function(d) data.frame(Length = d$x, Density = d$y, tag = "Simulated"))) %>%
select(-dens) %>% unnest(df)
# 观测的正态近似曲线（用 obs_sum 的均值与 sd）
obs_curve <- bind_rows(lapply(ages_plot, function(a){
mu <- obs_sum$mn_obs[obs_sum$Age == a]
sd <- obs_sum$sd_obs[obs_sum$Age == a]
if (length(mu) == 0 || length(sd) == 0 || !is.finite(sd) || sd <= 0) return(NULL)
xseq <- seq(xlim_fix[1], xlim_fix[2], by = 1)
data.frame(Age = a, Length = xseq,
Density = dnorm(xseq, mean = mu, sd = sd),
tag = "Observed")
}))
lines_df <- bind_rows(obs_curve, sim_curve)
# 两组均值线的数据
means_sim <- out_tbl %>% filter(Age %in% ages_plot) %>%
transmute(Age, xintercept = mn_sim, tag = "Simulated")
means_obs <- obs_sum  %>% filter(Age %in% ages_plot) %>%
transmute(Age, xintercept = mn_obs, tag = "Observed")
# 注释文本（把位置固定在每个分面的右上角）
ann_sim <- out_tbl %>% filter(Age %in% ages_plot) %>%
transmute(Age, x = 395, y = 0.010,  # 这里的 y 按 density 轴，必要时微调
lab = paste0("sim: mn=", round(mn_sim,1), "\nsd=", round(sd_sim,1)))
ann_obs <- obs_sum %>% filter(Age %in% ages_plot) %>%
transmute(Age, x = 395, y = 0.020,
lab = paste0("obs: mn=", round(mn_obs,1), "\nsd=", round(sd_obs,1)))
library(scales)
# 在主图最后加上 scale_y_continuous(second.axis=...)，同时计算缩放因子
# 假设每龄鱼样本数接近 max_n，个数≈密度×max_n×bin宽
max_n <- max(obs_sum$n, na.rm=TRUE)
bin_w <- diff(xlim_fix)[1] / nbins    # 粗略宽度
ggplot() +
geom_histogram(data = hdat %>% filter(Source=="Observed"),
aes(x=Length, y=after_stat(density), fill="Observed"),
bins=nbins, position="identity", alpha=0.28, color=NA) +
geom_histogram(data = hdat %>% filter(Source=="Simulated"),
aes(x=Length, y=after_stat(density), fill="Simulated"),
bins=nbins, position="identity", alpha=0.28, color=NA) +
geom_line(data=lines_df,
aes(x=Length, y=Density, color=tag, linetype=tag),
linewidth=1) +
scale_linetype_manual(values=c(Simulated="solid", Observed="dashed")) +
geom_vline(data=means_obs,
aes(xintercept=xintercept, color="Observed", linetype="Observed"),
linewidth=0.8, alpha=0.9) +
geom_vline(data=means_sim,
aes(xintercept=xintercept, color="Simulated", linetype="Simulated"),
linewidth=0.8, alpha=0.9) +
geom_text(data=ann_obs, aes(x=x, y=y, label=lab),
hjust=1, vjust=1, size=3.2, color="#D55E00", lineheight=1.05) +
geom_text(data=ann_sim, aes(x=x, y=y, label=lab),
hjust=1, vjust=1, size=3.2, color="#1F78B4", lineheight=1.05) +
facet_wrap(~Age, ncol=3, labeller=label_both) +
coord_cartesian(xlim=xlim_fix) +
scale_fill_manual(values=c(Observed="#E69F00", Simulated="#56B4E9"),
guide=guide_legend(title=NULL, override.aes=list(alpha=0.45))) +
scale_color_manual(values=c(Observed="#D55E00", Simulated="#1F78B4"),
guide=guide_legend(title=NULL)) +
scale_y_continuous(
name = "Density",
sec.axis = sec_axis(~ . * max_n * bin_w,
name = "Count", labels = comma)
) +
labs(x="Length (mm)",
title="Observed vs Simulated Length Distributions (Ages 0–5)",
subtitle="Semi-transparent histograms overlaid; left axis: density, right axis: counts") +
theme_bw(base_size=12) +
theme(
legend.position = "top",
legend.box = "vertical",
panel.grid = element_blank(),
strip.background = element_rect(fill="#F3F3F3", color=NA),
strip.text = element_text(face="bold"),
plot.title = element_text(face="bold")
)
